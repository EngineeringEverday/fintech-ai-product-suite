# PayCommander -- environment variables
#
# DEFAULT: deterministic mock-only mode. No keys required.
# Set the toggle below to "1" to wire real Anthropic / OpenAI calls into
# the Agent 1 classifier and Agent 5 formatter (extension hook only --
# the current build keeps the deterministic path even if these are set).

PAYCOMMANDER_USE_LLM=0

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# PAYCOMMANDER_API=http://localhost:8000   # for the Streamlit frontend
