# KYB Donut env example - copy to .env
# Model mode: 'mock' (default, no GPU/HF download), 'donut' (real Donut inference)
MODEL_MODE=mock
DONUT_MODEL_NAME=naver-clova-ix/donut-base
DONUT_CHECKPOINT_DIR=/data/checkpoints/donut-kyb-best

REDIS_URL=redis://redis:6379/0
DATABASE_URL=sqlite:////data/kyb.db

MLFLOW_TRACKING_URI=http://mlflow:5500

# Confidence thresholds
DOC_REVIEW_THRESHOLD=0.80
NAME_MATCH_THRESHOLD=0.85
EXPIRY_DAYS_FLAG=30

# Logging
LOG_LEVEL=INFO
